SECRET_KEY=change-me-in-production-use-long-random-string
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.docker

DB_NAME=ten_clinic
DB_USER=ten_clinic
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# IP Droplet, домен, web — для healthcheck і internal DNS
ALLOWED_HOSTS=tenclinic.com.ua,www.tenclinic.com.ua,104.248.31.202,127.0.0.1,localhost,web
CSRF_TRUSTED_ORIGINS=https://tenclinic.com.ua,https://www.tenclinic.com.ua
USE_HTTPS=false
SECURE_SSL_REDIRECT=False
HTTP_PORT=80

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@tenclinic.ua
NOTIFICATION_EMAIL=admin@tenclinic.ua

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

